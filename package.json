{
  "name": "makima-companion",
  "version": "1.0.0",
  "author": "Astralcloud_SZA (Devak)",
  "description": "Makima AI Holographic Companion",
  "main": "./out/main/index.js",
  "scripts": {
    "dev":      "electron-vite dev",
    "build":    "electron-vite build",
    "preview":  "electron-vite preview",
    "clean":    "rimraf out dist",
    "dist":     "npm run clean && electron-vite build && electron-builder",
    "dist:dir": "npm run clean && electron-vite build && electron-builder --dir"
  },
  "build": {
    "appId":       "com.makima.companion",
    "productName": "Makima Companion",
    "copyright":   "Copyright © 2026 Astralcloud_SZA (Devak)",
    "icon":        "build/icon2.ico",

    "directories": {
      "output":         "dist",
      "buildResources": "build"
    },

    "files": [
      "out/**/*",
      "!out/**/*.map",
      "!**/*.d.ts"
    ],

    "extraResources": [
      {
        "from":   "src/sidecar/dist_bin",
        "to":     "sidecar",
        "filter": ["tts_server.exe"]
      },
      {
        "from":   "src/sidecar",
        "to":     "sidecar",
        "filter": [
          "makima_voice.pt",
          "makima_raw.wav"
        ]
      },
      {
        "from":   "resources/models",
        "to":     "models",
        "filter": ["**/*.vrm", "**/*.vrma", "**/*.glb"]
      }
    ],

    "win": {
      "icon":   "build/icon2.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "asInvoker",
      "sign": null
    },

    "nsis": {
      "oneClick":    false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":            "build/icon2.ico",
      "uninstallerIcon":          "build/icon2.ico",
      "deleteAppDataOnUninstall": true
    },

    "asar":        true,
    "asarUnpack":  ["resources/sidecar/**"],
    "compression": "maximum"
  },

  "dependencies": {
    "@pixiv/three-vrm":           "^2.1.3",
    "@pixiv/three-vrm-animation": "^3.5.0",
    "three":                      "^0.164.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils":   "^3.0.0",
    "@types/three":              "^0.164.0",
    "electron":                  "33.3.1",
    "electron-builder":          "25.1.8",
    "electron-vite":             "2.3.0",
    "rimraf":                    "^5.0.0",
    "typescript":                "^5.6.3",
    "vite":                      "5.4.10"
  }
}
